<!--
  ╔══════════════════════════════════════════════════╗
  ║  SERVICES SECTION                                ║
  ║  4-column grid showing core offerings:            ║
  ║  01 Residential, 02 Commercial & Industrial,      ║
  ║  03 Solar Farms, 04 Maintenance.                  ║
  ║  Each card features numbered heading, SVG icon,   ║
  ║  and hover-reveal accent underline bar.           ║
  ╚══════════════════════════════════════════════════╝
-->
<section class="py-32 border-t" style="background: var(--bg-primary); border-color: var(--border);" id="services">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-20 animate-on-scroll">
      <div>
        <span class="text-sm font-medium tracking-[0.2em] uppercase block mb-4" style="color: var(--accent);">What We Do</span>
        <h2 class="text-4xl md:text-6xl font-black tracking-tight uppercase leading-[0.95]" style="color: var(--text-primary);">Our Services</h2>
      </div>
      <p class="max-w-md text-lg leading-relaxed" style="color: var(--text-secondary);">End-to-end solar solutions for every scale — from rooftop to megawatt.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px rounded-2xl overflow-hidden" style="background: var(--border);">
      <div class="animate-on-scroll group p-8 md:p-10 transition-all duration-500" style="background: var(--bg-card);">
        <div class="flex items-center justify-between mb-6">
          <span class="text-6xl font-black transition-colors duration-500" style="color: var(--text-faint);">01</span>
          <svg class="w-10 h-10 transition-colors duration-500" style="color: var(--accent-glow);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <h3 class="font-bold text-lg mb-3 uppercase tracking-wide" style="color: var(--text-primary);">Residential Solar</h3>
        <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Clean, affordable rooftop solar for homes of all sizes with quick installation and full warranty.</p>
        <div class="w-8 h-px mt-6 transition-all duration-500 group-hover:w-12" style="background: var(--accent);"></div>
      </div>
      <div class="animate-on-scroll animate-delay-100 group p-8 md:p-10 transition-all duration-500" style="background: var(--bg-card);">
        <div class="flex items-center justify-between mb-6">
          <span class="text-6xl font-black transition-colors duration-500" style="color: var(--text-faint);">02</span>
          <svg class="w-10 h-10 transition-colors duration-500" style="color: var(--accent-glow);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="8" y1="12" x2="8" y2="16"/><line x1="16" y1="12" x2="16" y2="16"/></svg>
        </div>
        <h3 class="font-bold text-lg mb-3 uppercase tracking-wide" style="color: var(--text-primary);">Commercial & Industrial</h3>
        <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Powering businesses and factories with high-capacity, reliable solar systems at scale.</p>
        <div class="w-8 h-px mt-6 transition-all duration-500 group-hover:w-12" style="background: var(--accent);"></div>
      </div>
      <div class="animate-on-scroll animate-delay-200 group p-8 md:p-10 transition-all duration-500" style="background: var(--bg-card);">
        <div class="flex items-center justify-between mb-6">
          <span class="text-6xl font-black transition-colors duration-500" style="color: var(--text-faint);">03</span>
          <svg class="w-10 h-10 transition-colors duration-500" style="color: var(--accent-glow);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </div>
        <h3 class="font-bold text-lg mb-3 uppercase tracking-wide" style="color: var(--text-primary);">Solar Farms</h3>
        <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Large-scale ground-mounted solar farms for maximum energy generation and ROI.</p>
        <div class="w-8 h-px mt-6 transition-all duration-500 group-hover:w-12" style="background: var(--accent);"></div>
      </div>
      <div class="animate-on-scroll animate-delay-300 group p-8 md:p-10 transition-all duration-500" style="background: var(--bg-card);">
        <div class="flex items-center justify-between mb-6">
          <span class="text-6xl font-black transition-colors duration-500" style="color: var(--text-faint);">04</span>
          <svg class="w-10 h-10 transition-colors duration-500" style="color: var(--accent-glow);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
        </div>
        <h3 class="font-bold text-lg mb-3 uppercase tracking-wide" style="color: var(--text-primary);">Maintenance</h3>
        <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Ongoing support, cleaning, and maintenance to keep your solar system at peak performance.</p>
        <div class="w-8 h-px mt-6 transition-all duration-500 group-hover:w-12" style="background: var(--accent);"></div>
      </div>
    </div>
  </div>
</section>
