<!--
  ╔══════════════════════════════════════════════════╗
  ║  NAVBAR COMPONENT                                ║
  ║  Fixed top navigation with:                      ║
  ║  - Glass-morphism backdrop blur                   ║
  ║  - Dark/light theme toggle (pill button)          ║
  ║  - Responsive mobile hamburger menu               ║
  ║  - Dharti Solar logo + CTA button                 ║
  ╚══════════════════════════════════════════════════╝
-->
---
import logoImg from '../images/dhartisolarlogo.png';
---
<nav class="fixed top-0 left-0 w-full z-50 backdrop-blur-2xl backdrop-saturate-150 border-b transition-all duration-500" style="background: var(--bg-nav); border-color: var(--border);">
  <div class="max-w-7xl mx-auto flex items-center justify-between px-6 md:px-12 py-3">
    <a href="#" class="flex items-center gap-2.5">
      <img src={logoImg.src} alt="Dharti Solar" class="h-10 w-auto" />
    </a>
    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Open menu">
      <span class="w-6 h-0.5 transition-all duration-300" style="background: var(--text-primary);"></span>
      <span class="w-6 h-0.5 transition-all duration-300" style="background: var(--text-primary);"></span>
      <span class="w-4 h-0.5 transition-all duration-300" style="background: var(--text-primary);"></span>
    </button>
    <div class="hidden md:flex items-center gap-10">
      <a href="#services" class="text-xs hover:opacity-100 transition-colors duration-200 tracking-[0.15em] uppercase font-medium" style="color: var(--text-secondary);">Services</a>
      <a href="#why-us" class="text-xs hover:opacity-100 transition-colors duration-200 tracking-[0.15em] uppercase font-medium" style="color: var(--text-secondary);">Why Us</a>
      <a href="#subsidy" class="text-xs hover:opacity-100 transition-colors duration-200 tracking-[0.15em] uppercase font-medium" style="color: var(--text-secondary);">Subsidy</a>
      <a href="#calculator" class="text-xs hover:opacity-100 transition-colors duration-200 tracking-[0.15em] uppercase font-medium" style="color: var(--text-secondary);">Calculator</a>
      <a href="#brands" class="text-xs hover:opacity-100 transition-colors duration-200 tracking-[0.15em] uppercase font-medium" style="color: var(--text-secondary);">Brands</a>
      <a href="#projects" class="text-xs hover:opacity-100 transition-colors duration-200 tracking-[0.15em] uppercase font-medium" style="color: var(--text-secondary);">Projects</a>
      <a href="#contact" class="text-xs hover:opacity-100 transition-colors duration-200 tracking-[0.15em] uppercase font-medium" style="color: var(--text-secondary);">Contact</a>
    </div>
    <div class="hidden md:flex items-center gap-4">
      <!-- Theme toggle -->
      <button class="theme-toggle" aria-label="Toggle theme">
        <span class="toggle-dot">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="dark-icon"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </span>
      </button>
      <a href="#contact" class="px-6 py-2.5 rounded-full font-bold text-xs tracking-[0.1em] uppercase shadow-lg hover:scale-105 transition-all duration-200" style="background: var(--accent); color: var(--accent-text); box-shadow: 0 4px 20px var(--shadow-accent);">Get Quote</a>
    </div>
  </div>
  <!-- Mobile nav -->
  <div id="mobile-menu" class="md:hidden max-h-0 overflow-hidden transition-all duration-500 backdrop-blur-xl" style="background: var(--bg-nav);">
    <div class="flex flex-col gap-4 px-6 py-6">
      <a href="#services" class="text-sm tracking-wider uppercase" style="color: var(--text-secondary);">Services</a>
      <a href="#why-us" class="text-sm tracking-wider uppercase" style="color: var(--text-secondary);">Why Us</a>
      <a href="#subsidy" class="text-sm tracking-wider uppercase" style="color: var(--text-secondary);">Subsidy</a>
      <a href="#calculator" class="text-sm tracking-wider uppercase" style="color: var(--text-secondary);">Calculator</a>
      <a href="#brands" class="text-sm tracking-wider uppercase" style="color: var(--text-secondary);">Brands</a>
      <a href="#projects" class="text-sm tracking-wider uppercase" style="color: var(--text-secondary);">Projects</a>
      <a href="#contact" class="text-sm tracking-wider uppercase" style="color: var(--text-secondary);">Contact</a>
      <div class="flex items-center justify-between mt-2">
        <button class="theme-toggle" aria-label="Toggle theme">
          <span class="toggle-dot">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/></svg>
          </span>
        </button>
        <a href="#contact" class="px-6 py-3 rounded-full font-bold text-sm tracking-wider uppercase text-center" style="background: var(--accent); color: var(--accent-text);">Get Quote</a>
      </div>
    </div>
  </div>
</nav>
<div class="h-[64px]"></div>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    const menu = document.getElementById('mobile-menu');
    if (menu) {
      menu.style.maxHeight = menu.style.maxHeight === '0px' || !menu.style.maxHeight ? '400px' : '0px';
    }
  });
  document.querySelectorAll('#mobile-menu a').forEach(link => {
    link.addEventListener('click', () => {
      const menu = document.getElementById('mobile-menu');
      if (menu) menu.style.maxHeight = '0px';
    });
  });
</script>
