<!--
  ╔══════════════════════════════════════════════════╗
  ║  CONTACT SECTION                                 ║
  ║  Two-column layout:                              ║
  ║  Left:  Lead capture form via FormSubmit          ║
  ║         (support@dhartisolar.com)                  ║
  ║  Right: Phone, email, office address,             ║
  ║         working hours, Instagram link              ║
  ║  Bottom: Google Maps embed (Office 104/1 Floor    ║
  ║     Patidar Complex, Sagwara, Rajasthan 314032)   ║
  ╚══════════════════════════════════════════════════╝
-->
<section class="py-32" id="contact" style="background: var(--bg-primary); border-top: 1px solid var(--border);">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-20 animate-on-scroll">
      <div>
        <span class="text-sm font-medium tracking-[0.2em] uppercase block mb-4" style="color: var(--accent);">Contact</span>
        <h2 class="text-4xl md:text-6xl font-black tracking-tight uppercase leading-[0.95]" style="color: var(--text-primary);">Let's Go<br/>Solar Together</h2>
      </div>
      <p class="max-w-md text-lg leading-relaxed" style="color: var(--text-secondary);">Fill in the form and our team will contact you within 24 hours.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <form action="https://formsubmit.co/support@dhartisolar.com" method="POST" class="animate-on-scroll space-y-6">
        <!-- FormSubmit config -->
        <input type="hidden" name="_subject" value="New Lead from Dharti Solar Website" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_next" value="" id="form-redirect" />
        <input type="text" name="_honey" style="display:none" />

        <div>
          <label for="name" class="block text-xs font-medium mb-3 uppercase tracking-[0.15em]" style="color: var(--text-secondary);">Full Name</label>
          <input type="text" id="name" name="name" placeholder="Your full name" required class="w-full px-0 py-4 border-0 border-b bg-transparent focus:ring-0 outline-none transition-colors text-lg" style="border-color: var(--border); color: var(--text-primary); --tw-placeholder-opacity: 1;" />
        </div>
        <div>
          <label for="phone" class="block text-xs font-medium mb-3 uppercase tracking-[0.15em]" style="color: var(--text-secondary);">Phone Number</label>
          <input type="tel" id="phone" name="phone" placeholder="Your phone number" required class="w-full px-0 py-4 border-0 border-b bg-transparent focus:ring-0 outline-none transition-colors text-lg" style="border-color: var(--border); color: var(--text-primary);" />
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="location" class="block text-xs font-medium mb-3 uppercase tracking-[0.15em]" style="color: var(--text-secondary);">Location / City</label>
            <input type="text" id="location" name="location" placeholder="Your city or area" required class="w-full px-0 py-4 border-0 border-b bg-transparent focus:ring-0 outline-none transition-colors text-lg" style="border-color: var(--border); color: var(--text-primary);" />
          </div>
          <div>
            <label for="email" class="block text-xs font-medium mb-3 uppercase tracking-[0.15em]" style="color: var(--text-secondary);">Email (Optional)</label>
            <input type="email" id="email" name="email" placeholder="Your email" class="w-full px-0 py-4 border-0 border-b bg-transparent focus:ring-0 outline-none transition-colors text-lg" style="border-color: var(--border); color: var(--text-primary);" />
          </div>
        </div>
        <div>
          <label for="message" class="block text-xs font-medium mb-3 uppercase tracking-[0.15em]" style="color: var(--text-secondary);">Message (Optional)</label>
          <textarea id="message" name="message" rows="3" placeholder="Tell us about your requirement..." class="w-full px-0 py-4 border-0 border-b bg-transparent focus:ring-0 outline-none transition-colors text-lg resize-none" style="border-color: var(--border); color: var(--text-primary);"></textarea>
        </div>
        <div class="pt-4">
          <button type="submit" class="group inline-flex items-center gap-3 px-10 py-4 rounded-full font-bold text-sm uppercase tracking-[0.1em] shadow-xl hover:scale-105 transition-all duration-300" style="background: var(--accent); color: var(--accent-text); box-shadow: 0 4px 25px var(--shadow-accent);">
            Get Free Quote
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>
      </form>

      <div class="animate-on-scroll animate-delay-200 flex flex-col justify-center">
        <div class="space-y-8">
          <div>
            <span class="text-xs font-medium tracking-[0.2em] uppercase block mb-3" style="color: var(--text-muted);">Phone</span>
            <a href="tel:+917300132924" class="text-3xl md:text-4xl font-black tracking-tight transition-colors" style="color: var(--text-primary);">+91 73001 32924</a>
          </div>
          <div class="w-full h-px" style="background: var(--border);"></div>
          <div>
            <span class="text-xs font-medium tracking-[0.2em] uppercase block mb-3" style="color: var(--text-muted);">Email</span>
            <a href="mailto:support@dhartisolar.com" class="text-lg transition-colors" style="color: var(--text-secondary);">support@dhartisolar.com</a>
          </div>
          <div class="w-full h-px" style="background: var(--border);"></div>
          <div>
            <span class="text-xs font-medium tracking-[0.2em] uppercase block mb-3" style="color: var(--text-muted);">Head Office</span>
            <p class="text-lg leading-relaxed" style="color: var(--text-secondary);">Dharti Solar Rooftop Solutions<br/>Vagad Group of Education<br/>Office 104/1 Floor, Patidar Complex<br/>Sagwara, Rajasthan 314032</p>
            <a href="https://maps.app.goo.gl/tzvnrV2qPq74VRnT7" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-3 text-sm transition-colors" style="color: var(--accent);">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              View on Google Maps
            </a>
          </div>
          <div class="w-full h-px" style="background: var(--border);"></div>
          <div>
            <span class="text-xs font-medium tracking-[0.2em] uppercase block mb-3" style="color: var(--text-muted);">Working Hours</span>
            <p class="text-lg" style="color: var(--text-secondary);">Mon–Sat: 9:00 AM – 7:00 PM</p>
          </div>
          <div class="w-full h-px" style="background: var(--border);"></div>
          <div>
            <span class="text-xs font-medium tracking-[0.2em] uppercase block mb-3" style="color: var(--text-muted);">Follow Us</span>
            <a href="https://www.instagram.com/dharti_solar/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 transition-colors" style="color: var(--text-secondary);">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
              @dharti_solar
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Embedded Map -->
    <div class="animate-on-scroll mt-16 rounded-2xl overflow-hidden h-[300px]" style="border: 1px solid var(--border);">
      <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3634.123456789!2d74.0123456789!3d23.6789012345!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sSagwara%2C+Rajasthan+314032!5e0!3m2!1sen!2sin!4v1234567890" width="100%" height="100%" style="border:0; filter: var(--map-filter);" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Dharti Solar Office Location"></iframe>
    </div>
  </div>
</section>

<script>
  // Set the _next redirect to current page so user comes back after submission
  const redirectField = document.getElementById('form-redirect') as HTMLInputElement;
  if (redirectField) {
    redirectField.value = window.location.href;
  }
</script>
