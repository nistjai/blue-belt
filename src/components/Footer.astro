<!--
  ╔══════════════════════════════════════════════════╗
  ║  FOOTER COMPONENT                                ║
  ║  Site-wide footer with:                          ║
  ║  - Dharti Solar logo + tagline                    ║
  ║  - Instagram & WhatsApp social links              ║
  ║  - Quick Links, Service Areas, Contact columns    ║
  ║  - Copyright © 2026 + Google Maps pin link         ║
  ╚══════════════════════════════════════════════════╝
-->
---
import logoImg from '../images/dhartisolarlogo.png';
---
<footer class="pt-20 pb-8" style="background: var(--bg-primary); border-top: 1px solid var(--border); color: var(--text-muted);">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 mb-16">
      <div class="lg:col-span-2">
        <img src={logoImg.src} alt="Dharti Solar" class="h-12 w-auto mb-5" />
        <p class="text-sm leading-relaxed max-w-sm" style="color: var(--text-muted);">Premium solar installations for homes, businesses, and solar farms. Powering a cleaner, greener India since 2020.</p>
        <div class="flex items-center gap-4 mt-6">
          <a href="https://www.instagram.com/dharti_solar/" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full flex items-center justify-center transition-all" style="background: var(--bg-card-alt);" aria-label="Instagram">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="https://wa.me/917300132924" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full flex items-center justify-center transition-all" style="background: var(--bg-card-alt);" aria-label="WhatsApp">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>
      <div>
        <h3 class="text-xs font-medium uppercase tracking-[0.2em] mb-6" style="color: var(--text-secondary);">Quick Links</h3>
        <ul class="space-y-3 text-sm">
          <li><a href="#services" class="transition-colors" style="color: var(--text-muted);">Services</a></li>
          <li><a href="#why-us" class="transition-colors" style="color: var(--text-muted);">Why Choose Us</a></li>
          <li><a href="#subsidy" class="transition-colors" style="color: var(--text-muted);">Subsidy Scheme</a></li>
          <li><a href="#calculator" class="transition-colors" style="color: var(--text-muted);">Solar Calculator</a></li>
          <li><a href="#projects" class="transition-colors" style="color: var(--text-muted);">Projects</a></li>
          <li><a href="#contact" class="transition-colors" style="color: var(--text-muted);">Contact</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-medium uppercase tracking-[0.2em] mb-6" style="color: var(--text-secondary);">Service Areas</h3>
        <ul class="space-y-3 text-sm">
          <li>Gujarat</li>
          <li>Rajasthan</li>
          <li>Madhya Pradesh</li>
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-medium uppercase tracking-[0.2em] mb-6" style="color: var(--text-secondary);">Contact</h3>
        <ul class="space-y-3 text-sm">
          <li><a href="tel:+917300132924" class="transition-colors" style="color: var(--text-muted);">+91 73001 32924</a></li>
          <li><a href="mailto:support@dhartisolar.com" class="transition-colors" style="color: var(--text-muted);">support@dhartisolar.com</a></li>
          <li class="leading-relaxed">Office 104/1 Floor,<br/>Patidar Complex, Sagwara,<br/>Rajasthan 314032</li>
          <li>Mon–Sat: 9 AM – 7 PM</li>
        </ul>
      </div>
    </div>
    <div class="pt-6 flex flex-col md:flex-row items-center justify-between gap-4 text-xs" style="border-top: 1px solid var(--border); color: var(--text-faint);">
      <span>&copy; 2026 Dharti Solar Rooftop Solutions. All rights reserved.</span>
      <a href="https://maps.app.goo.gl/tzvnrV2qPq74VRnT7" target="_blank" rel="noopener noreferrer" class="transition-colors" style="color: var(--text-faint);">
        <svg class="w-3.5 h-3.5 inline mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Sagwara, Rajasthan
      </a>
    </div>
  </div>
</footer>
